rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Mapa de competências: qualquer um pode LER, só admin pode ESCREVER
    match /config/competency-map {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == "SEU_UID_DE_ADMIN";
    }

    // Progresso dos usuários: cada um acessa apenas os próprios dados
    match /users/{uid}/data/{document} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
